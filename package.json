{
  "name": "sales-system-backend",
  "version": "1.0.0",
  "description": "نظام المبيعات المتقدم مع MongoDB والأمان والتدقيق",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:watch": "jest --runInBand --watch --forceExit --detectOpenHandles",
    "seed:rbac": "node scripts/seed-rbac.js"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/globalSetup.js",
    "globalTeardown": "./tests/globalTeardown.js",
    "testTimeout": 30000,
    "verbose": true
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": "^18 || ^20"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
