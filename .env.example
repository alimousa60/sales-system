# ============================================
# نظام المبيعات - ملف الإعدادات
# ============================================

# منفذ الخادم
PORT=3000

# اتصال قاعدة البيانات MongoDB
# المحلي: mongodb://localhost:27017/sales-system
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/sales-system
MONGODB_URI=mongodb://localhost:27017/sales-system

# الأمان - JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
JWT_EXPIRES_IN=2h

# CORS - السماح للنطاقات المرغوبة
CORS_ORIGIN=http://localhost:5500

# البيئة
NODE_ENV=development
